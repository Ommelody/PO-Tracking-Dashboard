rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ชุดข้อมูล PO/GR ที่ประมวลผลแล้ว
    // เริ่มต้นแบบเปิด (อ่าน/เขียนได้ทุกคน) เพื่อให้ใช้งานได้ทันที
    // *** แนะนำให้จำกัดสิทธิ์ภายหลัง (ดู README หัวข้อ "ความปลอดภัย") ***
    match /po_datasets/{document=**} {
      allow read, write: if true;
    }
  }
}
